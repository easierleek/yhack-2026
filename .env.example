# ============================================================
#  NEO — Nodal Energy Oracle
#  .env.example — Committed Template (no real keys)
#
#  Copy this file to .env and fill in your real values.
#
#    cp .env.example .env
#
#  .env is in .gitignore and will never be pushed to GitHub.
# ============================================================

# ─── K2 Think V2 API ─────────────────────────────────────────────────────────
# Get this from the K2 sponsor table at YHack
K2_API_KEY=

# ─── EIA API ─────────────────────────────────────────────────────────────────
# Free key — register at https://www.eia.gov/opendata/
# Approval is instant
EIA_API_KEY=

# ─── Arduino Serial Port ──────────────────────────────────────────────────────
# Windows:   COM3  (check Arduino IDE → Tools → Port)
# Mac/Linux: /dev/tty.usbmodemXXXX
NEO_SERIAL_PORT=COM3

# ─── Simulation Speed ────────────────────────────────────────────────────────
# Simulated seconds per real second.
# 60 = 1 real minute equals 1 simulated hour (default)
SIM_SPEED=60

# ─── K2 Call Interval ────────────────────────────────────────────────────────
# How often (real seconds) to call the K2 API.
# 2.0 is a safe default — lower = more responsive but burns API budget faster.
K2_CALL_INTERVAL=2.0
