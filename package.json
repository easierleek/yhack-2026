{
  "name": "neo-power",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "cd frontend/web && npm install --include=dev && npm run build",
    "start": "serve -s frontend/web/dist -l tcp://0.0.0.0:${PORT:-3000}",
    "frontend:dev": "cd frontend/web && npm run dev",
    "frontend:build": "cd frontend/web && npm run build",
    "frontend:preview": "cd frontend/web && npm run preview"
  },
  "dependencies": {
    "serve": "^14.2.5"
  }
}
